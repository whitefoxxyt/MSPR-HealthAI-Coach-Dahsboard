# Configuration de l'API backend
# Par défaut, utilise les données mockées
VITE_USE_MOCK=true

# URL du service d'authentification (better-auth / Hono, port 3000)
VITE_AUTH_BASE_URL=http://localhost:3000

# URL de l'API backend Java (à configurer lors de l'intégration réelle)
VITE_API_BASE_URL=http://localhost:8080/api

# URL du microservice AI Nutrition (FastAPI, port 8001) : preferences LLM
VITE_AI_NUTRITION_BASE_URL=http://localhost:8001
