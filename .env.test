# Build d'application servi a Cypress en mode "test".
# - Les URL pointent vers des hotes mockes par cy.intercept (jamais contactes).
# - VITE_ADMIN_EMAILS fixe l'admin attendu par les specs (cf. cypress.config.js).
VITE_USE_MOCK=false
VITE_AUTH_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8080/api
VITE_AI_NUTRITION_BASE_URL=http://localhost:8001
VITE_RECO_FITNESS_BASE_URL=http://localhost:8002
VITE_ADMIN_EMAILS=admin@healthai.local
